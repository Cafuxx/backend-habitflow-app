#:kivy 2.3
#:import MDRaisedButton kivymd.uix.button.MDRaisedButton
#:import MDTextField kivymd.uix.textfield.MDTextField
#:import MDFlatButton kivymd.uix.button.MDFlatButton

# ─────────────────────────────────────────────────────────────
#  ProfileScreen layout
#  Bound to: habit_app.screens.profile_screen.ProfileScreen
#
#  Exposes:
#    - display_email  (read-only)
#    - display_name   (editable)
#    - status_message (save/error feedback)
#    - is_loading     (spinner)
# ─────────────────────────────────────────────────────────────

<ProfileScreen>:
    name: "profile"

    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: app.theme_cls.bg_normal

        # ── Top App Bar ───────────────────────────────────────
        MDTopAppBar:
            title: "My Profile"
            left_action_items:
                [["arrow-left", lambda x: root.on_back_pressed(), "Back"]]
            md_bg_color: app.theme_cls.primary_color
            specific_text_color: 1, 1, 1, 1
            elevation: 2

        # ── Content ───────────────────────────────────────────
        MDScrollView:
            MDBoxLayout:
                orientation: "vertical"
                padding: dp(32)
                spacing: dp(20)
                adaptive_height: True

                # ── Avatar placeholder ────────────────────────
                MDIcon:
                    icon: "account-circle"
                    halign: "center"
                    font_size: dp(80)
                    theme_text_color: "Custom"
                    text_color: app.theme_cls.primary_color

                # ── Email (read-only) ─────────────────────────
                MDTextField:
                    hint_text: "Email"
                    text: root.display_email
                    mode: "rectangle"
                    icon_right: "email-outline"
                    readonly: True
                    size_hint_x: 1

                # ── Display name ──────────────────────────────
                MDTextField:
                    id: name_field
                    hint_text: "Display name"
                    text: root.display_name
                    mode: "rectangle"
                    icon_right: "account-outline"
                    size_hint_x: 1

                # ── Status / feedback label ───────────────────
                MDLabel:
                    text: root.status_message
                    halign: "center"
                    font_style: "Caption"
                    theme_text_color: "Secondary"
                    size_hint_y: None
                    height: dp(20)
                    opacity: 1 if root.status_message else 0

                # ── Spinner ───────────────────────────────────
                MDSpinner:
                    size_hint: None, None
                    size: dp(36), dp(36)
                    pos_hint: {"center_x": 0.5}
                    active: root.is_loading
                    opacity: 1 if root.is_loading else 0
                    size_hint_y: None
                    height: dp(36) if root.is_loading else 0

                # ── Save button ───────────────────────────────
                MDRaisedButton:
                    text: "SAVE CHANGES"
                    size_hint_x: 1
                    height: dp(50)
                    on_release: root.on_save_pressed()
                    disabled: root.is_loading

                Widget:
                    size_hint_y: None
                    height: dp(16)

                # ── Divider ───────────────────────────────────
                MDSeparator:

                Widget:
                    size_hint_y: None
                    height: dp(16)

                # ── Log out button ────────────────────────────
                MDRaisedButton:
                    text: "LOG OUT"
                    size_hint_x: 1
                    height: dp(50)
                    md_bg_color: app.theme_cls.error_color
                    on_release: root.on_signout_pressed()
