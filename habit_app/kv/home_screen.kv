#:kivy 2.3

# ─────────────────────────────────────────────────────────────
#  HomeScreen layout
#  Bound to: habit_app.screens.home_screen.HomeScreen
# ─────────────────────────────────────────────────────────────

<HomeScreen>:
    name: "home"

    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: app.theme_cls.backgroundColor

        # ── Top App Bar ───────────────────────────────────────
        MDTopAppBar:
            title: "HabitFlow"
            right_action_items:
                [["account-circle-outline", lambda x: root.on_profile_pressed(), "Profile"]]
            md_bg_color: app.theme_cls.primaryColor
            specific_text_color: 1, 1, 1, 1
            elevation: 2

        # ── Motivational quote strip ─────────────────────────
        MDCard:
            size_hint_y: None
            height: dp(72)
            padding: dp(16), dp(8)
            md_bg_color: app.theme_cls.primaryColor
            radius: [0, 0, dp(16), dp(16)]
            elevation: 1

            MDLabel:
                text: root.quote_text
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 0.92
                font_style: "Caption"
                halign: "center"
                valign: "middle"

        # ── Loading spinner (overlays content during refresh) ─
        MDSpinner:
            size_hint: None, None
            size: dp(40), dp(40)
            pos_hint: {"center_x": 0.5, "center_y": 0.5}
            active: root.is_loading
            opacity: 1 if root.is_loading else 0

        # ── Habit list ────────────────────────────────────────
        MDScrollView:
            MDList:
                id: habit_list
                padding: dp(8)
                spacing: dp(8)

        # ── FAB: Create Habit ─────────────────────────────────
        MDFloatingActionButton:
            icon: "plus"
            pos_hint: {"right": 0.95, "y": 0.04}
            md_bg_color: app.theme_cls.primaryColor
            on_release: root.on_create_habit_pressed()
            elevation: 4
